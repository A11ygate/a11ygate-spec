{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://a11ygate.github.io/schemas/audit-report.schema.json",
  "title": "A11yGate Audit Report",
  "description": "Canonical output schema v0.1.0. Conforms to VALIDATION.md v0.1.0.",
  "type": "object",
  "additionalProperties": false,
  "required": ["report_id","schema_version","document_name","audit_timestamp",
    "spec_version","validation_spec_version","render_profile","font_analyzed",
    "scores","trs","penalty","status","confidence","badge","recommendations",
    "validation_fingerprint"],
  "properties": {
    "report_id":    {"type":"string","pattern":"^AG-[0-9]{8}-[A-Za-z0-9]{6}$"},
    "schema_version": {"type":"string","const":"0.1.0"},
    "document_name": {"type":"string"},
    "audit_timestamp": {"type":"string","format":"date-time"},
    "spec_version": {"type":"string"},
    "validation_spec_version": {"type":"string"},
    "render_profile": {"type":"string"},
    "input_type": {"type":"string","enum":["font","document","url","css"]},
    "entity_scope": {"type":"string","enum":["sigwell","caretide","kindergurus","external","internal"]},
    "font_analyzed": {"type":"object","required":["name","weight","sha256"],"properties":{
      "name": {"type":"string"}, "version": {"type":["string","null"]},
      "weight": {"type":"integer","minimum":100,"maximum":900},
      "sha256": {"type":["string","null"]}, "format": {"type":"string"},
      "axis_values": {"type":"object"}, "upm": {"type":"integer"}}},
    "scores": {"type":"object","required":["character_ambiguity","spacing_safety",
      "stroke_contrast_stability","small_size_rendering","render_delta_consistency"],
      "properties":{
        "character_ambiguity": {"$ref":"#/definitions/category_score"},
        "spacing_safety": {"$ref":"#/definitions/category_score"},
        "stroke_contrast_stability": {"$ref":"#/definitions/category_score"},
        "small_size_rendering": {"$ref":"#/definitions/category_score"},
        "render_delta_consistency": {"$ref":"#/definitions/category_score"}}},
    "trs": {"type":"number","minimum":0,"maximum":100},
    "trs_raw": {"type":"number","minimum":0,"maximum":100},
    "penalty": {"type":"number","enum":[1.0,0.85,0.75]},
    "penalty_trigger": {"type":["string","null"]},
    "status": {"type":"string","enum":["certified","approved","conditional","risk","fail"]},
    "gate_state": {"type":"string","enum":["pass","conditional_pass","fail","waived","expired"]},
    "expiry_at": {"type":["string","null"],"format":"date-time"},
    "remediation_due": {"type":["string","null"],"format":"date-time"},
    "waiver_reason": {"type":["string","null"]},
    "waiver_owner": {"type":["string","null"]},
    "parent_par_id": {"type":["string","null"],"description":"Supersedes chain"},
    "supersedes_version": {"type":"integer","default":1},
    "confidence": {"type":"string","enum":["HIGH","MEDIUM","LOW"]},
    "confidence_notes": {"type":"array","items":{"type":"string"}},
    "badge": {"type":"object","required":["issued","type"],"properties":{
      "issued": {"type":"boolean"},
      "type": {"type":["string","null"],"enum":["validated","reviewed","risk_flag",null]},
      "text": {"type":["string","null"]},
      "svg_url": {"type":["string","null"],"format":"uri"}}},
    "recommendations": {"type":"array","items":{"type":"object","required":["category","severity","finding","action"],
      "properties":{
        "category": {"type":"string","enum":["CA","SS","SCS","SSR","RDC","GENERAL"]},
        "severity": {"type":"string","enum":["FAIL","RISK","WARNING","INFO"]},
        "finding": {"type":"string"}, "action": {"type":"string"},
        "expected_impact": {"type":["string","null"]}}}},
    "validation_fingerprint": {"type":"object",
      "required":["fingerprint_id","font_sha256","spec_version","audit_timestamp","auditor"],
      "properties":{
        "fingerprint_id": {"type":"string","pattern":"^AG-[0-9]{8}-[A-Za-z0-9]{6}$"},
        "font_version": {"type":["string","null"]},
        "font_sha256": {"type":["string","null"]},
        "spec_version": {"type":"string"},
        "validation_spec_version": {"type":"string"},
        "axis_values": {"type":["object","null"]},
        "render_profile": {"type":"string"},
        "audit_timestamp": {"type":"string","format":"date-time"},
        "auditor": {"type":"string","enum":["a11ygate-pipeline","a11ygate-api","a11ygate-cli","a11ygate-plugin"]},
        "enforcement_override": {"type":"boolean","default":false}}}},
  "definitions": {
    "category_score": {"type":"object","required":["score","status"],"properties":{
      "score": {"type":"number","minimum":0,"maximum":100},
      "status": {"type":"string","enum":["PASS","RISK","FAIL"]},
      "notes": {"type":["string","null"]}}}}
}
